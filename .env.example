# Build inputs. Set GEYSER_SHA256 to pin and verify a specific artifact.
GEYSER_IMAGE=aspel/geysermc:latest
GEYSER_DOWNLOAD_URL=https://download.geysermc.org/v2/projects/geyser/versions/latest/builds/latest/downloads/standalone
GEYSER_SHA256=

# Download GEYSER_DOWNLOAD_URL at every container start. Disabled by default.
GEYSER_SYNC=false

# Bedrock listener. GEYSER_PUBLISHED_PORT is the host-side UDP port.
GEYSER_UDP_ADDRESS=0.0.0.0
GEYSER_UDP_PORT=19132
GEYSER_PUBLISHED_PORT=19132
GEYSER_BROADCAST_PORT=19132

# ViaProxy reached by Geyser on the private Compose network.
GEYSER_JAVA_SERVER_ADDRESS=viaproxy
GEYSER_JAVA_SERVER_PORT=25568
JAVA_AUTH_TYPE=online

# Official ViaProxy image and private listener.
VIAPROXY_IMAGE=ghcr.io/viaversion/viaproxy:latest
VIAPROXY_PORT=25568
VIAPROXY_PUBLISHED_PORT=25565
VIAPROXY_PROXY_ONLINE_MODE=false
VIAPROXY_AUTH_METHOD=NONE

# Vanilla server on the private Compose network.
MINECRAFT_IMAGE=itzg/minecraft-server:latest
MINECRAFT_TYPE=VANILLA
MINECRAFT_VERSION=LATEST
MINECRAFT_MEMORY=2G
MINECRAFT_UID=1000
MINECRAFT_GID=1000
MINECRAFT_ONLINE_MODE=TRUE
VANILLA_SERVER_ADDRESS=mc
VANILLA_SERVER_PORT=25565
VANILLA_PROTOCOL_VERSION=Auto Detect (1.7+ servers)

# Advanced properties are optional. Uncomment a value here and its matching
# line under `environment` in compose.yaml to enable it.
# GEYSER_PRINT_SECURE_CHAT_INFORMATION=true
# GEYSER_SHOW_SCOREBOARD_LOGS=true
# GEYSER_SHOW_RESOURCE_PACK_LENGTH_WARNING=true
# GEYSER_PRINT_PINGS_IN_DEBUG_MODE=true
# GEYSER_USE_DIRECT_ADAPTERS=true
# GEYSER_BEDROCK_NETWORK_THREADS=8
# GEYSER_ADD_TEAM_SUGGESTIONS=true
# GEYSER_NO_PLAYER_LIST_PS=false
# GEYSER_RAK_PACKET_LIMIT=120
# GEYSER_RAK_GLOBAL_PACKET_LIMIT=100000
# GEYSER_RAK_RATE_LIMITING_DISABLED=false
# GEYSER_RAK_SEND_COOKIE=true

# JVM and container memory tuning.
MEMORY_LIMIT=1G
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC
VIAPROXY_MEMORY_LIMIT=1G
VIAPROXY_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC
